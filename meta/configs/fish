fish_default_key_bindings
bind alt-backspace backward-kill-word
bind alt-delete kill-word
bind ctrl-delete kill-token

alias emacs 'emacs -nw'
alias neofetch fastfetch

alias docker podman
alias docker-compose podman-compose

alias du2 ncdu

alias gst 'git status'

set -gx EDITOR "emacs"
set -gx PATH $HOME/.deno/bin $HOME/.pyenv/bin $HOME/bin /usr/local/bin $HOME/.bin $PATH

set -U fish_greeting

function start_sway
    dbus-run-session sway
end

function feh_mosaic
    feh --montage --thumb-height 200 --thumb-width 200 --index-info "%wx%h" --output .
end
